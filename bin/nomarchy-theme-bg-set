#!/bin/bash

# Sets the specified image as the current background

if [[ -z $1 ]]; then
  echo "Usage: nomarchy-theme-bg-set <path-to-image>" >&2
  exit 1
fi

BACKGROUND=$(realpath "$1")
CURRENT_BACKGROUND_LINK="$HOME/.config/nomarchy/current/background"

# Update symlink
ln -nsf "$BACKGROUND" "$CURRENT_BACKGROUND_LINK"

# Apply via hyprpaper IPC (only if hyprpaper is already running)
if pgrep -x hyprpaper > /dev/null; then
  hyprctl monitors -j | jq -r '.[].name' | while read -r monitor; do
    hyprctl hyprpaper wallpaper "$monitor,$BACKGROUND"
  done
fi
