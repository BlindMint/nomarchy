[Plymouth Theme]
Name=Arch Linux
Description=Arch Linux boot splash with official colors and logo
ModuleName=script

[script]
ImageDir=/usr/share/plymouth/themes/arch
ScriptFile=/usr/share/plymouth/themes/arch/arch.script
ConsoleLogBackgroundColor=0x0c0e14
MonospaceFont=Cantarell 11
Font=Cantarell 11
