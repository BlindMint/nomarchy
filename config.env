# config.env
# Edit before running usb-make. Passwords are prompted at runtime.

INSTALL_DISK= # {prompt user}      # Target disk (will be wiped)
INSTALL_USER="samurai"
INSTALL_HOSTNAME="archlinux"
INSTALL_TIMEZONE="America/Boise"
INSTALL_LOCALE="en_US.UTF-8"
INSTALL_KB_LAYOUT="us"
INSTALL_BOOT_SIZE="1G"            # EFI partition size